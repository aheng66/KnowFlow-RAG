# Copy this file to `.env`, `.env.test`, or `.env.prod` as needed.
# These VITE_* values are bundled into the frontend, so keep them public.

VITE_BASE_URL=/
VITE_APP_TITLE=KnowFlow
VITE_APP_DESC=KnowFlow

VITE_ICON_PREFIX=icon
VITE_ICON_LOCAL_PREFIX=icon-local

VITE_AUTH_ROUTE_MODE=static
VITE_ROUTE_HOME=chat
VITE_MENU_ICON=mdi:menu

VITE_HTTP_PROXY=Y
VITE_ROUTER_HISTORY_MODE=hash

VITE_SERVICE_SUCCESS_CODE=200
VITE_SERVICE_LOGOUT_CODES=8888,8889
VITE_SERVICE_MODAL_LOGOUT_CODES=7777,7778
VITE_SERVICE_EXPIRED_TOKEN_CODES=9999,9998,3333

VITE_STATIC_SUPER_ROLE=ADMIN
VITE_SOURCE_MAP=N
VITE_STORAGE_PREFIX=KnowFlow_
VITE_AUTOMATICALLY_DETECT_UPDATE=Y
VITE_PROXY_LOG=Y
VITE_DEVTOOLS_LAUNCH_EDITOR=code
VITE_WS_TIMEOUT=10000

# Backend endpoints. Use relative paths in production behind the same domain.
VITE_SERVICE_BASE_URL=/api/v1
VITE_OTHER_SERVICE_BASE_URL=`{
  "api": "/api/v1",
  "ws": "/"
}`

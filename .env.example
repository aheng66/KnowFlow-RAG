# Copy this file to `.env` and replace every `change-me-*` value before running.
# Do not commit `.env`; it is ignored by git.

# Spring profile
SPRING_PROFILES_ACTIVE=dev
APP_TIMEZONE=Asia/Shanghai

# Server
SERVER_PORT=8081

# MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/KnowFlow?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me-mysql-password

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=change-me-redis-password

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
SPRING_KAFKA_TOPIC_PARTITIONS=1
SPRING_KAFKA_TOPIC_REPLICATION_FACTOR=1

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET_NAME=uploads

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=https
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=change-me-elasticsearch-password
ELASTICSEARCH_INSECURE_TRUST_ALL_CERTIFICATES=true

# JWT secret must be a Base64 string, for example from: openssl rand -base64 32
JWT_SECRET_KEY=change-me-base64-jwt-secret

# One-time admin bootstrap. Disable it after the first admin account is created.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-admin-bootstrap-password
ADMIN_BOOTSTRAP_PRIMARY_ORG=default
ADMIN_BOOTSTRAP_ORG_TAGS=default,admin

# Registration
APP_AUTH_REGISTRATION_MODE=INVITE_ONLY
APP_AUTH_INVITE_REQUIRED=true

# Browser/WebSocket allowed origins. Separate multiple origins with commas.
SECURITY_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# LLM provider
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_API_MODEL=deepseek-chat
DEEPSEEK_API_KEY=change-me-deepseek-api-key

# Embedding provider
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_MODEL=text-embedding-v4
EMBEDDING_API_KEY=change-me-embedding-api-key
EMBEDDING_BATCH_SIZE=10
EMBEDDING_DIMENSION=2048

# Log level
LOG_LEVEL_APP=INFO

# Frontend deployment helper
DEPLOY_SERVER_HOST=
DEPLOY_SERVER_USER=
DEPLOY_SERVER_KEY=/absolute/path/to/private-key.pem
DEPLOY_TARGET_DIR=/home/www/KnowFlow-Front
DEPLOY_HEALTHCHECK_URL=
DEPLOY_HEALTHCHECK_TIMEOUT=15

# WeChat Pay
WX_PAY_ENABLE=false
WX_PAY_APP_ID=
WX_PAY_MERCHANT_ID=
WX_PAY_PRIVATE_KEY=
WX_PAY_MERCHANT_SERIAL_NUMBER=
WX_PAY_API_V3_KEY=
WX_PAY_NOTIFY_URL=
WX_PAY_REFUND_NOTIFY_URL=
